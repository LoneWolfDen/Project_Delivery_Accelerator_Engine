# ─────────────────────────────────────────────────────────────────────────────
# Project Delivery Accelerator Engine – Environment Variables
#
# Copy this file to .env and fill in values before running with Docker.
#   cp .env.example .env
#
# ADMIN_PIN is the only required value. Everything else is optional.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# PIN required for destructive operations (archive, delete projects).
# Must be set before first run. No default — the app will reject operations
# that require a PIN if this is not configured.
ADMIN_PIN=changeme


# ── Server ────────────────────────────────────────────────────────────────────

# Port the server listens on inside the container (mapped in docker-compose).
PORT=8080

# Display name shown in the Web UI header and API responses.
APP_NAME=Project Delivery Accelerator Engine


# ── AI Backends (all optional — app works offline without any of these) ───────

# Groq — fast, free tier available (https://console.groq.com)
GROQ_API_KEY=

# OpenRouter — 300+ models, free tier available (https://openrouter.ai)
OPENROUTER_API_KEY=

# Google Gemini (https://aistudio.google.com)
GEMINI_API_KEY=

# AWS Bedrock — uses boto3 credential chain
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Ollama — set automatically to http://ollama:11434 when using docker-compose
# with --profile ollama. Override here only if running Ollama separately.
# OLLAMA_HOST=http://localhost:11434
