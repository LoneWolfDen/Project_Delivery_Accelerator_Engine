  <diagram id="data-flow" name="Data Flow (User Journey)">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="df-title" value="&lt;b&gt;USER JOURNEY: Document → Intelligence → Review&lt;/b&gt;" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="500" height="30" as="geometry" />
        </mxCell>


        <!-- STEP 1: Upload Documents -->
        <mxCell id="df-s1" value="&lt;b&gt;1. UPLOAD&lt;/b&gt;&lt;br&gt;&lt;br&gt;User provides file paths&lt;br&gt;(.txt, .md, .csv, .eml)&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#82b366&quot;&gt;✓ BUILT&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="180" height="100" as="geometry" />
        </mxCell>
        <!-- STEP 2: Ingest & Parse -->
        <mxCell id="df-s2" value="&lt;b&gt;2. INGEST&lt;/b&gt;&lt;br&gt;&lt;br&gt;Parse → detect type →&lt;br&gt;extract sections →&lt;br&gt;store as IngestedDocument&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#82b366&quot;&gt;✓ BUILT&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="280" y="80" width="180" height="100" as="geometry" />
        </mxCell>
        <!-- STEP 3: Build Intelligence -->
        <mxCell id="df-s3" value="&lt;b&gt;3. BUILD INTELLIGENCE&lt;/b&gt;&lt;br&gt;&lt;br&gt;Extract: risks, assumptions,&lt;br&gt;dependencies, constraints,&lt;br&gt;scope, action items&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#82b366&quot;&gt;✓ BUILT&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="520" y="80" width="190" height="100" as="geometry" />
        </mxCell>
        <!-- STEP 4: Review -->
        <mxCell id="df-s4" value="&lt;b&gt;4. PERSONA REVIEW&lt;/b&gt;&lt;br&gt;&lt;br&gt;Select persona + backend&lt;br&gt;Add custom prompt&lt;br&gt;AI analyses context&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#82b366&quot;&gt;✓ BUILT&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="770" y="80" width="180" height="100" as="geometry" />
        </mxCell>
        <!-- STEP 5: Iterate -->
        <mxCell id="df-s5" value="&lt;b&gt;5. ITERATE&lt;/b&gt;&lt;br&gt;&lt;br&gt;Compare versions&lt;br&gt;Track evolution&lt;br&gt;Refine documents&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#82b366&quot;&gt;✓ BUILT&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1010" y="80" width="170" height="100" as="geometry" />
        </mxCell>
        <!-- Flow arrows -->
        <mxCell id="df-a1" style="rounded=1;strokeColor=#666;strokeWidth=2;" edge="1" source="df-s1" target="df-s2" parent="1">
